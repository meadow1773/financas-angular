{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "migrate": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/config/scripts/migrate.ts",
    "generate-interfaces": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/config/scripts/generateInterfaces.ts",
    "start": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/server.ts",
    "dev": "npm run migrate && npm run generate-interfaces && nodemon --exec npm start",
    "build": "tsc",
    "serve": "npm run build && node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.1",
    "@types/pg": "^8.15.4",
    "nodemon": "^3.1.10",
    "ts-morph": "^26.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
