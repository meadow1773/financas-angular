{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "strict": true,
    "removeComments": true,
    "moduleResolution": "node",
    "rootDir": "./",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"],
  "compileOnSave": true
}