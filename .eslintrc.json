{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "semi": ["error", "never"],
    "indent": ["error", 2],
    "no-console": "warn",
    "no-unused-vars": "error",
    "no-undef": "error",
    "eqeqeq": "error",
    "no-trailing-spaces": "error",
    "eol-last": "error",
    "no-multiple-empty-lines": ["error", { "max": 2 }]
  }
}